---
import type { SiteCopy } from "@/data/site";

type Props = {
  copy: SiteCopy["process"];
};

const { copy } = Astro.props;
---

<section class="process-wrap" id="gcComoWrap">
  <section class="scene scene--dark process" id="gc-como">
    <div class="gc-container process__inner">
      <p class="process__eyebrow">
        <span class="process__eyebrow-num">{copy.index}</span>{copy.eyebrow}
      </p>
      <h2 class="process__title">
        <span>{copy.title.prefix}</span>
        <em>{copy.title.accent}</em>
      </h2>

      <div class="process__stage">
        <div class="process__line" aria-hidden="true">
          <span class="process__line-track"></span>
          <span class="process__line-active"></span>
        </div>

        <div class="process__beats">
          {
            copy.items.map((item, index) => (
              <article class="process__beat" data-process-beat data-step={index}>
                <div class="process__beat-num">{`0${index + 1}`}</div>
                <h3>{item.title}</h3>
                <p>{item.body}</p>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</section>
